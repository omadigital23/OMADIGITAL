/**
 * Visualiseur Audio pour le chatbot multimodal OMA
 * 
 * Affiche le niveau audio en temps réel pendant l'enregistrement vocal
 * Optimisé pour les performances (Web Worker optionnel selon cahier des charges)
 * Compatible PC et mobile
 */

import React, { useEffect, useRef } from 'react';
import { motion } from 'framer-motion';

interface AudioVisualizerProps {
  level: number; // 0-100
  size?: 'small' | 'medium' | 'large';
  className?: string;
}

export const AudioVisualizer: React.FC<AudioVisualizerProps> = ({ 
  level, 
  size = 'small',
  className = '' 
}) => {
  const canvasRef = useRef<HTMLCanvasElement>(null);
  const animationRef = useRef<number>();

  const dimensions = {
    small: { width: 40, height: 20, bars: 5 },
    medium: { width: 60, height: 30, bars: 7 },
    large: { width: 80, height: 40, bars: 10 }
  };

  const { width, height, bars } = dimensions[size];

  useEffect(() => {
    const canvas = canvasRef.current;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const draw = () => {
      // Clear canvas
      ctx.clearRect(0, 0, width, height);

      // Configuration
      const barWidth = width / bars;
      const maxBarHeight = height - 4;

      // Générer des hauteurs de barres basées sur le niveau audio
      for (let i = 0; i < bars; i++) {
        // Hauteur basée sur le niveau + variation aléatoire pour effet visuel
        const baseHeight = (level / 100) * maxBarHeight;
        const randomVariation = Math.random() * 0.3 + 0.7; // 0.7 à 1.0
        const barHeight = Math.max(2, baseHeight * randomVariation);
        
        // Position
        const x = i * barWidth + barWidth * 0.2;
        const y = height - barHeight - 2;
        const actualBarWidth = barWidth * 0.6;

        // Couleur basée sur l'intensité
        const intensity = barHeight / maxBarHeight;
        let color;
        if (intensity < 0.3) {
          color = '#10B981'; // vert
        } else if (intensity < 0.7) {
          color = '#F59E0B'; // orange
        } else {
          color = '#EF4444'; // rouge
        }

        // Dessiner la barre avec effet de dégradé
        const gradient = ctx.createLinearGradient(x, y + barHeight, x, y);
        gradient.addColorStop(0, color + '40'); // transparent
        gradient.addColorStop(1, color);

        ctx.fillStyle = gradient;
        ctx.fillRect(x, y, actualBarWidth, barHeight);
      }

      animationRef.current = requestAnimationFrame(draw);
    };

    // Démarrer l'animation seulement si le niveau > 0
    if (level > 0) {
      draw();
    } else {
      ctx.clearRect(0, 0, width, height);
    }

    return () => {
      if (animationRef.current) {
        cancelAnimationFrame(animationRef.current);
      }
    };
  }, [level, width, height, bars]);

  return (
    <motion.div
      className={`absolute -top-8 left-1/2 transform -translate-x-1/2 bg-black bg-opacity-75 rounded px-2 py-1 ${className}`}
      initial={{ opacity: 0, scale: 0.8 }}
      animate={{ opacity: 1, scale: 1 }}
      exit={{ opacity: 0, scale: 0.8 }}
    >
      <canvas
        ref={canvasRef}
        width={width}
        height={height}
        className="block"
      />
    </motion.div>
  );
};

export default AudioVisualizer;