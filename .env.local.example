# ============================================================
# OMA Digital — Environment Variables Template
# Copy this file to .env.local and fill in your values
# ============================================================

# SUPABASE
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# GROQ AI (Chatbot)
GROQ_API_KEY=your_groq_api_key

# SMTP (Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_user
SMTP_PASSWORD=your_brevo_password
SMTP_FROM_EMAIL=support@omadigital.net
SMTP_FROM_NAME=OMA DIGITAL
SMTP_SUPPORT_EMAIL=support@omadigital.net

# WHATSAPP (CallMeBot)
CALLMEBOT_PHONE=your_phone_number
CALLMEBOT_API_KEY=your_callmebot_api_key

# GOOGLE ANALYTICS
NEXT_PUBLIC_GA_ID=your_ga4_id

# VERCEL
VERCEL_API_TOKEN=your_vercel_token

# SITE
NEXT_PUBLIC_SITE_URL=https://www.omadigital.net
NEXT_PUBLIC_DOMAIN=https://www.omadigital.net
